# GHL Private Integration token — server-side only (no VITE_ prefix, never bundled to the client)
GHL_KEY=your-private-integration-key-here

# GHL Location ID
GHL_LOCATION_ID=your-location-id-here

# Pipeline & stage
PIPELINE_ID=your-pipeline-id-here
STAGE_ID=your-stage-id-here

# Branch → GHL Personal calendar
GHL_CALENDAR_CAVITE=your-cavite-calendar-id-here
GHL_CALENDAR_BATANGAS=your-batangas-calendar-id-here

# Supabase — menu/pricing data (client-side, safe to expose) and the
# proof-of-payment flow (server-side only, via api/_supabase-admin.js)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public base URL of this deployed site — used to build the ?pay=<token>
# payment link returned by api/create-payment-link.js
SITE_URL=https://your-deployed-site.com

# Shared secret checked against the X-Webhook-Secret header on
# api/create-payment-link.js — set this to a long random string, then paste
# the SAME value into the GHL Workflow's Webhook action custom header.
GHL_WEBHOOK_SECRET=your-long-random-secret-here
